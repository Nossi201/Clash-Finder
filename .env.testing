# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Secret Key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-in-production

# Riot API Configuration
RIOT_API_KEY=RGAPI-your-riot-api-key-here
RIOT_API_TIMEOUT=10

# Redis Configuration (optional - for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0
# Or for Redis with password:
# REDIS_URL=redis://:password@localhost:6379/0

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Data Dragon Version
DDRAGON_VERSION=14.1.1
# Get latest version from: https://ddragon.leagueoflegends.com/api/versions.json

# SSL/HTTPS Configuration (production)
SSL_ENABLED=False
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# Rate Limiting
RATE_LIMIT_ENABLED=True

# Cache Configuration
CACHE_MAX_SIZE=1000

# Resource Updates
AUTO_UPDATE_RESOURCES=True
UPDATE_CHECK_INTERVAL_HOURS=24

# Database (if used in future)
# DATABASE_URL=sqlite:///clash_finder.db

# CORS (if needed for API)
ENABLE_CORS=False

# Production Settings (uncomment for production)
# FLASK_ENV=production
# DEBUG=False
# SSL_ENABLED=True
# SESSION_COOKIE_SECURE=True

# Gunicorn Settings (production)
# WEB_CONCURRENCY=4
# WORKER_CLASS=gevent
# WORKER_TIMEOUT=30

# Monitoring (optional)
# PROMETHEUS_ENABLED=False

# Admin Configuration (optional)
# ADMIN_TOKEN=your-admin-token-here
# API_KEY=your-api-key-here